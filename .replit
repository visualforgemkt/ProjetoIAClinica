modules = ["nodejs-18", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
NODE_ENV = "development"
PORT = "3001"
FRONTEND_URL = "http://localhost:5000"
JWT_EXPIRES_IN = "15m"
AI_DEFAULT_PROVIDER = "anthropic"
AI_DEFAULT_MODEL = "claude-haiku-4-5-20251001"
AI_MAX_TOKENS = "4096"
AI_TIMEOUT_MS = "90000"
RATE_LIMIT_WINDOW_MS = "60000"
RATE_LIMIT_MAX_REQUESTS = "60"
AI_RATE_LIMIT_MAX = "20"
AUTH_RATE_LIMIT_MAX = "10"
CODE_RATE_LIMIT_MAX = "5"
LOG_LEVEL = "info"
LOG_FILE = "logs/medai.log"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node src/server.js"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd frontend && npm run preview -- --port 5000 --host 0.0.0.0"]
build = ["bash", "-c", "cd frontend && npm install && npm run build"]
