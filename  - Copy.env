# ═══════════════════════════════════════════════════
# MedAI Pro Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no repositório
# ═══════════════════════════════════════════════════

# ── SERVIDOR ──
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── SUPABASE ──
# Encontre em: supabase.com → Settings → API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (nunca no frontend)
SUPABASE_ANON_KEY=eyJ...      # anon key (pode ir no frontend)

# ── JWT ──
JWT_SECRET=gere_uma_string_longa_e_aleatoria_aqui_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── BCRYPT ──
BCRYPT_ROUNDS=12

# ── PROVIDERS DE IA ──
# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (opcional — fallback)
OPENAI_API_KEY=sk-proj-...

# ── AI GATEWAY ──
# Provider padrão: 'anthropic' | 'openai'
AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=2048
AI_TIMEOUT_MS=60000

# ── RATE LIMITING ──
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
AI_RATE_LIMIT_MAX=20

# ── LOGS ──
LOG_LEVEL=info
LOG_FILE=logs/medai.log
