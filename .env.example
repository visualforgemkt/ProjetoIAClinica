NODE_ENV=development
PORT=3001

# FRONTEND — separar por vírgula para múltiplos domínios
# Exemplo produção: FRONTEND_URL=https://app.medaipro.com.br
# Exemplo dev: FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# Supabase — Settings → API no painel do Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Anthropic — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — opcional, usado como fallback caso Anthropic falhe
# OPENAI_API_KEY=sk-...

# JWT — OBRIGATÓRIO: gerar com: openssl rand -base64 64
# NUNCA usar string previsível em produção
JWT_SECRET=GERAR_COM_openssl_rand_-base64_64
JWT_EXPIRES_IN=15m

# IA
AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-haiku-4-5-20251001
AI_MAX_TOKENS=4096
AI_TIMEOUT_MS=90000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
AI_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_MAX=10
CODE_RATE_LIMIT_MAX=5

# Logs
LOG_LEVEL=info
LOG_FILE=logs/medai.log