NODE_ENV=development
PORT=3001

# FRONTEND — separar por vírgula para múltiplos domínios
# Produção:  FRONTEND_URL=https://app.medaipro.com.br
# Dev:       FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Obter em: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Obter em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ── OpenAI — fallback opcional ────────────────────────────────────────────────
# Obter em: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# ── JWT ───────────────────────────────────────────────────────────────────────
# OBRIGATÓRIO: Gerar com:
#   node -e "const c=require('crypto');console.log(c.randomBytes(64).toString('base64'))"
# NUNCA usar string previsível em produção. NUNCA commitar a chave real.
JWT_SECRET=YOUR_STRONG_RANDOM_SECRET_MINIMUM_64_BYTES
JWT_EXPIRES_IN=15m

# ── IA ────────────────────────────────────────────────────────────────────────
AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-haiku-4-5-20251001
AI_MAX_TOKENS=4096
AI_TIMEOUT_MS=90000

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
AI_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_MAX=10
CODE_RATE_LIMIT_MAX=5

# ── Logs ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/medai.log